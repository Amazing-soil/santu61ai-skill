# Copy to ~/.config/minimax_tts/.env or to a project-local .env.
# Do not commit your real API key.

MINIMAX_API_KEY=replace_with_your_minimax_api_key
MINIMAX_API_BASE=https://api.minimaxi.com

# Optional defaults used by the local minimax-tts CLI.
# Override per command when needed.
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_VOICE_ID=SantuVoice20260618B
